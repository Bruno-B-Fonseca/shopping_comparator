# Cloudflare Tunnel Configuration (For Nodes)
#CLOUDFLARE_TUNNEL_TOKEN=your_token_here

# Ngrok Configuration (For Hub)
NGROK_AUTHTOKEN=seu_token_aqui
NGROK_DOMAIN=...ngrok-free.app

# Federation Configuration
# HUB_URL: The Hub MUST be at a fixed URL (e.g., wss://hub.yourdomain.com/ws).
# Local servers can use dynamic URLs because they initiate the connection to the Hub.
HUB_URL=ws://ngrok-domain:3001/ws
REGION=id-region

# Identificação da sua rede
HUB_ID=id-hub
HUB_SECRET=sua-chave-secreta-de-federacao

# Porta do Hub (padrão 3000)
HUB_PORT=3000

# Local Operator Credentials (MUST match hub/config/secrets.json)
LOCATION_ID=id-local
LOCATION_PASSWORD=password-local
LAT=-23.5505
LNG=-46.6333

# AI and Storage
AI_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
GEMINI_API_KEY=your_gemini_api_key_here