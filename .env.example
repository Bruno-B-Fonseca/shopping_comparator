# Cloudflare Tunnel Configuration
# If you have a Cloudflare account, create a tunnel and add the token here for a FIXED DNS.
# Leave it commented out or empty to use a TEMPORARY random URL.
#CLOUDFLARE_TUNNEL_TOKEN=your_token_here

# Federation Configuration
# HUB_URL: The Hub MUST be at a fixed URL (e.g., wss://hub.yourdomain.com).
# Local servers can use dynamic URLs because they initiate the connection to the Hub.
HUB_URL=ws://hub:3001
REGION=default-region

# Local Operator Credentials (MUST match hub/config/secrets.json)
LOCATION_ID=padaria-do-joao
LOCATION_PASSWORD=senha123

# AI and Storage
AI_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
GEMINI_API_KEY=your_gemini_api_key_here

# Public Access URLs (Update these after starting the tunnel)
PUBLIC_WS_URL=wss://merger-increasingly-evidence-firms.trycloudflare.com/ws
PUBLIC_URL=https://merger-increasingly-evidence-firms.trycloudflare.com
